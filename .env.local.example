# Supabase 接続設定
# Supabase ダッシュボード → Project Settings → Database → Connection string から取得

# 接続プーラー URL（アプリケーションのクエリ用）
# Transaction mode を使用 (port: 6543)
DATABASE_URL="postgresql://postgres.SUPABASE_PROJECT_ID:[PASSWORD]@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"

# 直接接続 URL（Prisma マイグレーション用）
# Session mode を使用 (port: 5432)
DIRECT_URL="postgresql://postgres.SUPABASE_PROJECT_ID:[PASSWORD]@aws-0-REGION.pooler.supabase.com:5432/postgres"
