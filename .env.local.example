# Supabase 接続設定
# Supabase ダッシュボード → Project Settings → API から取得

# Supabase プロジェクト URL（ランタイム・クライアント共通）
VITE_SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"

# Supabase 匿名キー（公開しても安全。RLS ポリシーで保護）
VITE_SUPABASE_ANON_KEY="your-anon-key"

# ──────────────────────────────────────────────────────────────
# Prisma マイグレーション用（prisma migrate deploy 実行時のみ必要）
# Supabase ダッシュボード → Project Settings → Database → Connection string から取得
# ──────────────────────────────────────────────────────────────

# 直接接続 URL（Session mode, port: 5432）— マイグレーション専用
# DIRECT_URL="postgresql://postgres.PROJECT_ID:[PASSWORD]@aws-0-REGION.pooler.supabase.com:5432/postgres"
