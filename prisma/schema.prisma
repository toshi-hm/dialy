generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  // url はドライバアダプター（@prisma/adapter-better-sqlite3）経由で
  // ランタイムに指定するため、スキーマでは省略しています。
  // 詳細: src/lib/infrastructure/prisma.ts
}

/// 日記エントリーテーブル
model DiaryEntry {
  id        String   @id @default(uuid())
  date      DateTime
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  /// 将来のマルチユーザー対応に備えたフィールド（現在は未使用）
  userId    String?  @map("user_id")

  tags DiaryEntryTag[]

  @@unique([date, userId])
  @@index([date])
  @@index([userId])
  @@map("diary_entries")
}

/// 日記エントリータグテーブル
model DiaryEntryTag {
  id      String @id @default(uuid())
  name    String
  entryId String @map("entry_id")

  entry DiaryEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@unique([entryId, name])
  @@index([entryId])
  @@map("diary_entry_tags")
}
