generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  // DATABASE_URL: Supabase の接続プーラー URL（本番・開発クエリ用）
  // DIRECT_URL: Supabase の直接接続 URL（マイグレーション用）
  // 詳細: .env.local.example を参照
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// 日記エントリーテーブル
model DiaryEntry {
  id        String   @id @default(uuid())
  date      DateTime
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  /// 将来のマルチユーザー対応に備えたフィールド（現在は未使用）
  userId    String?  @map("user_id")

  tags DiaryEntryTag[]

  @@unique([date, userId])
  @@index([date])
  @@index([userId])
  @@map("diary_entries")
}

/// 日記エントリータグテーブル
model DiaryEntryTag {
  id      String @id @default(uuid())
  name    String
  entryId String @map("entry_id")

  entry DiaryEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@unique([entryId, name])
  @@index([entryId])
  @@map("diary_entry_tags")
}
